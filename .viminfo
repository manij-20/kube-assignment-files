	apiVersion: networking.k8s.io/v1
	kind: Ingress
	metadata:
	  name: wordpress-jenkins-ingress
	  annotations:
	    nginx.ingress.kubernetes.io/rewrite-target: /
	spec:
	  ingressClassName: nginx
	  rules:
	  - host: wordpress.local
	    http:
	      paths:
	      - path: /
	        pathType: Prefix
	        backend:
	          service:
	            name: wordpress-service
	            port:
	              number: 80
	
	  - host: jenkins.local
	    http:
	      paths:
	      - path: /
	        pathType: Prefix
	        backend:
	          service:
	            name: jenkins-service
	            port:
	              number: 8080
