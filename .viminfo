	apiVersion: apps/v1
	kind: Deployment
	metadata:
	  name: nginx-deployment
	spec:
	  replicas: 2
	  strategy:
	    type: RollingUpdate
	    rollingUpdate:
	      maxSurge: 2
	      maxUnavailable: 1
	  selector:
	    matchLabels:
	      app: nginx
	  template:
	    metadata:
	      labels:
	        app: nginx
	    spec:
	      containers:
	        - name: nginx
	          image: nginx:1.29.5-perl
	      affinity:
	        podAffinity:
	          requiredDuringSchedulingIgnoredDuringExecution:
	            - labelSelector:
	                matchExpressions:
	                  - key: env
	                    operator: In
	                    values:
	                      - dev
	              topologyKey: "kubernetes.io/hostname"
